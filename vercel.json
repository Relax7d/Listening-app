{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "DEFAULT_API_KEY": {
      "description": "默认的API Key（可选）"
    },
    "DEFAULT_PROVIDER": "deepseek"
  }
}
